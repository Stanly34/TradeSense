{
  "name": "tradesense",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "TradeSense - Premium Trading Journal Platform",
  "scripts": {
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "dev": "concurrently -n client,server -c cyan,green \"npm run dev:client\" \"npm run dev:server\"",
    "build:client": "vite build --root client",
    "build:server": "npm run build --prefix server",
    "build": "npm run build:server && npm run build:client",
    "render-build": "npm install && npx prisma generate --schema=server/prisma/schema.prisma && cd server && npx tsc && cd .. && node -e \"fs.rmSync('client/node_modules',{recursive:true,force:true})\" && npx vite build --root client",
    "start": "node server/dist/server.js"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/ms": "^2.1.0",
    "@types/nodemailer": "^6.4.16",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.5.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.6.0",
    "nodemailer": "^6.9.16",
    "openai": "^4.77.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "prisma": "^6.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "tsx": "^4.19.0"
  }
}
