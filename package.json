{
  "name": "tradesense",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "TradeSense - Premium Trading Journal Platform",
  "scripts": {
    "dev:client": "cd client && npx vite",
    "dev:server": "cd server && npx tsx watch --env-file=.env src/server.ts",
    "dev": "concurrently -n client,server -c cyan,green \"npm run dev:client\" \"npm run dev:server\"",
    "build:client": "npx vite build --root client",
    "build:server": "npx tsc --project server/tsconfig.json",
    "build": "npm run build:server && npm run build:client",
    "render-build": "npm install && npx prisma generate --schema=server/prisma/schema.prisma && npx tsc --project server/tsconfig.json && npx vite build --root client",
    "start": "node server/dist/server.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.0.0",
    "@tanstack/react-query": "^5.101.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/ms": "^2.1.0",
    "@types/nodemailer": "^6.4.16",
    "axios": "^1.18.1",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.5.0",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "framer-motion": "^12.42.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.21.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.6.0",
    "nodemailer": "^6.9.16",
    "openai": "^4.77.0",
    "razorpay": "^2.9.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.80.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "oxlint": "^1.69.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^4.3.1",
